#!/usr/bin/env bash
# SessionStart hook for signet-first plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# --- CLAUDE.md enforcement ---
# Deploy signet-first rules into the project's CLAUDE.md if missing or outdated.
# The template contains a version comment; if the installed version is older
# (or the file doesn't exist), we inject/update the managed section.
TEMPLATE="${PLUGIN_ROOT}/templates/CLAUDE.md"
TARGET="CLAUDE.md"
MARKER="<!-- signet-first-version:"

if [ -f "$TEMPLATE" ]; then
  template_version=$(grep -oP '(?<=<!-- signet-first-version: )[\d.]+' "$TEMPLATE" 2>/dev/null || echo "0.0.0")

  if [ ! -f "$TARGET" ]; then
    # No CLAUDE.md at all — copy the template as-is
    cp "$TEMPLATE" "$TARGET"
  else
    # CLAUDE.md exists — check if it has a signet-first managed section
    installed_version=$(grep -oP '(?<=<!-- signet-first-version: )[\d.]+' "$TARGET" 2>/dev/null || echo "")

    if [ -z "$installed_version" ]; then
      # CLAUDE.md exists but has no signet-first section — prepend the template
      # preserving the user's existing content below the managed block
      tmp_file=$(mktemp)
      cat "$TEMPLATE" > "$tmp_file"
      echo "" >> "$tmp_file"
      cat "$TARGET" >> "$tmp_file"
      mv "$tmp_file" "$TARGET"
    elif [ "$installed_version" != "$template_version" ]; then
      # Outdated version — replace the managed section (above the end marker),
      # preserve everything below it (user's project-specific rules)
      END_MARKER="<!-- Do not edit above this line"
      tmp_file=$(mktemp)
      # Write the new managed section from the template
      sed "/${END_MARKER}/q" "$TEMPLATE" > "$tmp_file"
      # Append user content (everything after the end marker in the existing file)
      if user_content=$(sed -n "/${END_MARKER}/,\$p" "$TARGET" | tail -n +2); then
        echo "$user_content" >> "$tmp_file"
      fi
      mv "$tmp_file" "$TARGET"
    fi
    # If versions match, do nothing — already up to date
  fi
fi

# Read SKILL.md, stripping YAML frontmatter (everything between first two --- lines)
skill_content=$(awk 'BEGIN{fm=0} /^---$/{fm++; next} fm>=2{print}' "${PLUGIN_ROOT}/SKILL.md")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

skill_content_escaped=$(escape_for_json "$skill_content")

# Build session context with mandatory protocol header
session_context="IMPORTANT: The signet-first skill content is included below. It is ALREADY LOADED. Do NOT use the skill tool to load signet-first again.\n\nMANDATORY — ON EVERY TURN: Search Signet memory BEFORE firing explore/librarian agents, reading files, or taking any action.\n\n${skill_content_escaped}"

# Output context injection as JSON.
# Cursor hooks expect additional_context (snake_case).
# Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
# Copilot CLI (v1.0.11+) and others expect additionalContext (top-level, SDK standard).
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  # Cursor sets CURSOR_PLUGIN_ROOT (may also set CLAUDE_PLUGIN_ROOT)
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  # Claude Code sets CLAUDE_PLUGIN_ROOT without COPILOT_CLI
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  # Copilot CLI (sets COPILOT_CLI=1) or unknown platform — SDK standard format
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
